{
  "name": "EvaluationAttempt",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email del usuario que realiz\u00f3 el intento"
    },
    "subject_id": {
      "type": "string",
      "description": "ID de la materia asociada"
    },
    "lesson_id": {
      "type": "string",
      "description": "ID de la lecci\u00f3n/mini-evaluaci\u00f3n"
    },
    "type": {
      "type": "string",
      "enum": [
        "lesson",
        "mini_eval",
        "final_exam",
        "surprise_exam"
      ],
      "description": "Tipo de evaluaci\u00f3n"
    },
    "answers": {
      "type": "array",
      "description": "Respuestas del usuario con resultado calculado en backend",
      "items": {
        "type": "object",
        "properties": {
          "question_id": {
            "type": "string"
          },
          "user_answer": {
            "type": "string"
          },
          "correct": {
            "type": "boolean"
          },
          "points_obtained": {
            "type": "number"
          }
        }
      }
    },
    "score": {
      "type": "number",
      "description": "Puntuaci\u00f3n total (0-100), calculada en backend"
    },
    "passed": {
      "type": "boolean",
      "description": "\u00bfAprob\u00f3? score >= 80"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp de inicio del examen"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp de env\u00edo"
    },
    "attempt_number": {
      "type": "number",
      "description": "N\u00famero de intento para esta lecci\u00f3n/usuario"
    },
    "requires_manual_review": {
      "type": "boolean",
      "default": false,
      "description": "Requiere revisi\u00f3n manual por docente"
    },
    "reviewed_by": {
      "type": "string",
      "description": "Email del docente/admin revisor (\u00faltima revisi\u00f3n)"
    },
    "reviewer_id": {
      "type": "string",
      "description": "ID del usuario revisor (trazabilidad SEP)"
    },
    "reviewer_name": {
      "type": "string",
      "description": "Nombre completo del revisor"
    },
    "reviewer_role": {
      "type": "string",
      "description": "Rol del revisor al momento de la revisi\u00f3n (docente | admin)"
    },
    "review_decision": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ],
      "description": "Decisi\u00f3n de la \u00faltima revisi\u00f3n"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp de la \u00faltima revisi\u00f3n"
    },
    "review_started_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp en que el docente abri\u00f3 el intento para revisi\u00f3n"
    },
    "review_duration_seconds": {
      "type": "number",
      "description": "Segundos entre review_started_at y reviewed_at"
    },
    "feedback": {
      "type": "string",
      "description": "Comentarios de la \u00faltima revisi\u00f3n manual"
    },
    "review_locked_by": {
      "type": "string",
      "description": "ID del docente que tiene el intento bloqueado para revisi\u00f3n"
    },
    "review_locked_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp del bloqueo activo"
    },
    "review_history": {
      "type": "array",
      "description": "Historial completo e inmutable de todas las revisiones",
      "items": {
        "type": "object",
        "properties": {
          "reviewer_id": {
            "type": "string"
          },
          "reviewer_name": {
            "type": "string"
          },
          "reviewer_role": {
            "type": "string"
          },
          "decision": {
            "type": "string"
          },
          "feedback": {
            "type": "string"
          },
          "reviewed_at": {
            "type": "string"
          },
          "review_duration_seconds": {
            "type": "number"
          }
        }
      }
    }
  },
  "required": [
    "user_email",
    "subject_id",
    "lesson_id",
    "type",
    "answers",
    "started_at",
    "submitted_at",
    "attempt_number"
  ]
}